# Pinged — environment variables. Copy to `.env` (gitignored) and fill per machine.

# ── Shopify app (required for `shopify app dev`) ──────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,read_inventory
SHOPIFY_APP_URL=
SHOP_CUSTOM_DOMAIN=

# ── Email (Resend) — restock notification sends ──────────────────────────────
# Without a key, sends are logged in dev (not actually sent).
# DELIVERABILITY: onboarding@resend.dev goes to SPAM. For inbox delivery you MUST verify a
# sending domain (SPF/DKIM/DMARC) in Resend and set EMAIL_FROM to an address on it. See DELIVERABILITY.md.
RESEND_API_KEY=
EMAIL_FROM=Pinged <notify@yourdomain.com>
EMAIL_REPLY_TO=

# ── Worker (DB-backed send queue) ────────────────────────────────────────────
# Tick interval for the in-process send worker. Set DISABLE_WORKER=1 to turn it off (e.g. on dev).
WORKER_TICK_MS=15000
DISABLE_WORKER=
# Shared secret guarding POST /internal/process (manual worker trigger).
CRON_SECRET=
