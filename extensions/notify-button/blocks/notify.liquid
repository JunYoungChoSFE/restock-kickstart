{% comment %}
  Pinged — "입고 알림" app block.
  Add it to the product page (Theme editor > product template > Add block > Apps).
  Shows an email-capture form only when the product/variant is sold out.
  Submits to the App Proxy: /apps/pinged/subscribe → app proxy.subscribe.tsx.
{% endcomment %}

{%- assign v = product.selected_or_first_available_variant -%}
<div
  class="pinged-notify"
  data-pinged
  data-proxy="/apps/{{ block.settings.proxy_subpath }}"
  data-product-id="{{ product.id }}"
  data-product-title="{{ product.title | escape }}"
  data-variant-id="{{ v.id }}"
  data-variant-title="{{ v.title | escape }}"
  data-available="{{ v.available }}"
  style="--pinged-color: {{ block.settings.button_color }};"
>
  <form
    class="pinged-form"
    data-pinged-form
    {% if product.available %}hidden{% endif %}
  >
    <p class="pinged-heading">{{ block.settings.heading }}</p>
    <input
      class="pinged-input"
      type="email"
      name="email"
      placeholder="{{ block.settings.placeholder }}"
      autocomplete="email"
      required
    />
    <button class="pinged-btn" type="submit">{{ block.settings.button_text }}</button>
    <p class="pinged-msg" data-pinged-msg hidden></p>
  </form>
</div>

{% schema %}
{
  "name": "Back-in-stock button",
  "target": "section",
  "stylesheet": "notify.css",
  "javascript": "notify.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sold out — get notified when it's back"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Notify me when available"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "you@example.com"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "proxy_subpath",
      "label": "App proxy subpath (advanced — leave as pinged)",
      "default": "pinged"
    }
  ]
}
{% endschema %}
